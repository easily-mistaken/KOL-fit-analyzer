# Database (Supabase Postgres via Prisma) - added in Unit 03
DATABASE_URL=
DIRECT_URL=

# Twitter/X data provider selection - added in Unit 10 (optional; default "mock").
# "twitterapi" is wired in Unit 16.
TWITTER_PROVIDER=mock

# Twitter/X data provider (TwitterAPI.io) - added in Unit 16.
# Required only when TWITTER_PROVIDER=twitterapi. Never commit a real key.
TWITTERAPI_IO_KEY=
# Optional overrides (defaults: https://api.twitterapi.io , 15000ms).
TWITTERAPI_IO_BASE_URL=
TWITTERAPI_IO_TIMEOUT_MS=

# LLM provider selection - added in Unit 11 (optional; default "mock").
# "openai" is wired in Unit 17.
LLM_PROVIDER=mock

# LLM provider (OpenAI) - added in Unit 17.
# Required only when LLM_PROVIDER=openai. Never commit a real key.
OPENAI_API_KEY=
# Model identifier read at runtime; never hardcode a model name in code.
# Required for the openai provider; use a Structured-Outputs-capable model (GPT-4o+).
LLM_MODEL=
# Optional OpenAI overrides (defaults: https://api.openai.com/v1 , 120000ms).
OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=
# Reasoning effort for GPT-5-tier models (default "minimal"; set "off" for
# non-reasoning models like gpt-4o-mini).
OPENAI_REASONING_EFFORT=
# Max engaged accounts sent to OpenAI for per-account bucket labeling (default 300).
OPENAI_AUDIENCE_CLASSIFICATION_LIMIT=300
# Optional cheaper/faster model for bulk per-account audience batches (Unit 29B
# tiering). Defaults to LLM_MODEL when unset.
LLM_MODEL_FAST=
# Optional STRONGER model for the single pair-specific content-fit/relationship
# judgment call (Unit 30). Tiny call, big judgment — e.g. gpt-5. Defaults to LLM_MODEL.
LLM_MODEL_FIT=
# Max post images attached to the multimodal KOL content classification
# (Unit 29B). Default 12.
OPENAI_MEDIA_IMAGE_LIMIT=

# Caching and cost controls - added in Unit 19.
# Provider-data cache (DB-backed, worker-side). Set CACHE_ENABLED=false to
# disable caching entirely (every run refetches). TTLs are in seconds.
CACHE_ENABLED=true
# Base TTL for tweets/engagement (default 21600 = 6h).
CACHE_TTL_SECONDS=
CACHE_TTL_TWEETS_SECONDS=
# Profiles change slowly (default 86400 = 24h).
CACHE_TTL_PROFILE_SECONDS=
#
# Cross-analysis classification cache (Unit 23) — reuses the expensive LLM
# classifications (audience/content/org) across analyses, content-addressed by
# their inputs. Set CLASSIFICATION_CACHE_ENABLED=false to disable.
CLASSIFICATION_CACHE_ENABLED=true
# Base TTL for cached classifications (default 1209600 = 14 days).
CLASSIFICATION_CACHE_TTL_SECONDS=
# Optional per-kind overrides (default to the base TTL).
CLASSIFICATION_CACHE_TTL_AUDIENCE_SECONDS=
CLASSIFICATION_CACHE_TTL_CONTENT_SECONDS=
CLASSIFICATION_CACHE_TTL_ORG_SECONDS=
#
# Analysis depth / cost caps. Each override is optional and falls back to the
# built-in default (see architecture.md -> Analysis Depth and Cost Controls).
ANALYSIS_KOL_POSTS_FETCHED=
ANALYSIS_KOL_REPLIES_FETCHED=
ANALYSIS_TOP_POSTS_FOR_DEEP_ANALYSIS=
ANALYSIS_REPLIES_PER_POST=
ANALYSIS_QUOTES_PER_POST=
ANALYSIS_RETWEETERS_PER_POST=
ANALYSIS_MAX_UNIQUE_ENGAGED_ACCOUNTS=
# How many top posts fetch their engagement concurrently (Unit 29D). Default 6.
ANALYSIS_ENGAGEMENT_FETCH_CONCURRENCY=
#
# Optional LLM cost estimate (USD per million tokens). When both are unset,
# ProviderUsageLog still records raw token counts; costUsd is left null.
LLM_INPUT_COST_PER_MTOK=
LLM_OUTPUT_COST_PER_MTOK=

# Report delivery / lead capture (Unit 24). Email delivers the report PDF.
# MAIL_PROVIDER=mock (default) just logs — no email is sent, no key needed.
# Set MAIL_PROVIDER=resend + RESEND_API_KEY + MAIL_FROM (a verified sender) to
# actually send. Telegram is captured/stored but not delivered yet.
MAIL_PROVIDER=mock
RESEND_API_KEY=
MAIL_FROM=
MAIL_REPLY_TO=

# Abuse & cost controls (Unit 26). POST /api/analyses is PUBLIC and
# unauthenticated, and each run drives real paid TwitterAPI.io + OpenAI spend.
# These caps bound worst-case spend (rolling 24h windows) and set the transient-
# failure retry policy. All optional; each falls back to the built-in default.
# Per-owner-cookie cap (default 10) and the global spend-ceiling cap (default 200).
MAX_ANALYSES_PER_OWNER_PER_DAY=10
MAX_ANALYSES_PER_DAY=200
# Optional summed-provider-spend cap in USD over 24h; 0 (default) disables it.
MAX_DAILY_SPEND_USD=0
# Retry policy for transient provider failures (rate-limit/timeout/outage).
ANALYSIS_MAX_ATTEMPTS=3
ANALYSIS_RETRY_DELAY_SECONDS=60

# Admin panel (Unit 27). A single shared password gates the read-only operator
# panel at /admin (usage, analyses across all browsers, captured email/Telegram
# leads, provider spend). FAIL-CLOSED: leave this unset/empty and the panel is
# disabled entirely — it is never open by default. Rotating the value logs every
# existing admin session out. Never commit a real password.
ADMIN_PASSWORD=

# User auth (Unit 28). Dev email login by default (localhost). Set the two
# NEXT_PUBLIC_SUPABASE_* vars to switch to real Supabase Auth (deploy).
AUTH_SESSION_SECRET=            # required for dev login; a long random string
# AUTH_DEV_LOGIN=true           # allow passwordless dev login in production (unsafe; off by default)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public app URL used by the web app
NEXT_PUBLIC_APP_URL=http://localhost:3000
