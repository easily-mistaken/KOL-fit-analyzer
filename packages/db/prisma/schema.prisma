generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ReportStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ReportVerdict {
  STRONG
  GOOD
  OKAY
  WEAK
  AVOID
}

enum EngagementSource {
  REPLY
  QUOTE
  RETWEET
  FOLLOWER
}

// Real per-user identity (Unit 28). Additive: ownership ids on AnalysisRequest
// stay a free string that holds EITHER an anonymous cookie id OR a User.id, so
// there is deliberately NO foreign key from AnalysisRequest.ownerId to User
// (existing cookie-owned rows would violate it). In dev mode `id` is a cuid; in
// Supabase mode it is the Supabase auth UUID (mirror-upserted on login).
model User {
  id          String    @id @default(cuid())
  email       String    @unique
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?
}

// Captured email addresses (Unit 44). The self-serve flow deliberately needs
// no account, which means an anonymous visitor could take a full report and
// leave nothing behind — this is the row that closes that gap.
//
// One row PER EMAIL (upserted), not per submission: for outreach a person is a
// person, and a second submission should refresh them rather than create a
// duplicate to chase twice. `firstSource` records where they were first
// captured, since intent differs a lot by capture point.
//
// `ownerId` holds EITHER an anonymous cookie id OR a User.id and has no FK, for
// exactly the reason documented on the User model above.
model Lead {
  id      String  @id @default(cuid())
  email   String  @unique
  ownerId String?

  firstSource String
  // What they were looking at when they left the email — the outreach hook.
  analysisRequestId String?
  orgHandle         String?
  kolHandle         String?
  note              String?

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  // Operator workflow, mirroring DetailedReportRequest: `seenAt` drives the
  // nav badge, `contactedAt` records that outreach actually happened.
  seenAt      DateTime? @db.Timestamptz
  contactedAt DateTime? @db.Timestamptz

  @@index([createdAt])
  @@index([seenAt])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  requests AnalysisRequest[]
  reports  Report[]
}

model AnalysisRequest {
  id          String  @id @default(cuid())
  workspaceId String?
  // Anonymous per-browser owner (Unit 25). Set from a private cookie; scopes
  // report visibility to the browser that created the analysis (pre-auth).
  ownerId     String?

  orgHandle String
  kolHandle String

  websiteUrl      String?
  docsUrl         String?
  productCategory String?
  targetUser      String?
  campaignGoal    String?
  stage           String?
  region          String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  workspace  Workspace?         @relation(fields: [workspaceId], references: [id])
  job        AnalysisJob?
  report     Report?
  orgProfile OrgProfile?
  kolProfile KolProfile?
  usageLogs  ProviderUsageLog[]

  @@index([workspaceId, createdAt])
  @@index([ownerId, createdAt])
  @@index([orgHandle])
  @@index([kolHandle])
  @@index([createdAt])
  // Instant reuse (Unit 41): most-recent completed run for this owner + exact
  // pair, newest-first. Equality on (ownerId, orgHandle, kolHandle) + order on
  // createdAt — this composite serves the reuse lookup as an index-only scan.
  @@index([ownerId, orgHandle, kolHandle, createdAt])
}

model AnalysisJob {
  id        String    @id @default(cuid())
  requestId String    @unique
  status    JobStatus @default(QUEUED)
  attempts  Int       @default(0)

  pgBossJobId  String?
  errorCode    String?
  errorMessage String?

  // Live analysis progress for the waiting screen (AnalysisProgress JSON,
  // @kol-fit/shared): real stage + public profile/audience-share glimpses the
  // worker writes as the pipeline clears stage boundaries. Nullable; reset when
  // a job (re)enters RUNNING. Presentation-only — never read by scoring.
  progress Json?

  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  startedAt   DateTime? @db.Timestamptz
  completedAt DateTime? @db.Timestamptz
  failedAt    DateTime? @db.Timestamptz

  request AnalysisRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model OrgProfile {
  id        String @id @default(cuid())
  requestId String @unique

  handle         String
  displayName    String?
  bio            String?
  followersCount Int?
  followingCount Int?
  verified       Boolean?

  normalized     Json?
  classification Json?

  fetchedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz

  request AnalysisRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([handle])
}

model KolProfile {
  id        String @id @default(cuid())
  requestId String @unique

  handle         String
  displayName    String?
  bio            String?
  followersCount Int?
  followingCount Int?
  postsAnalyzed  Int?

  normalized            Json?
  contentClassification Json?

  fetchedAt DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz

  request AnalysisRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([handle])
}

model Report {
  id          String       @id @default(cuid())
  requestId   String       @unique
  workspaceId String?
  status      ReportStatus @default(PENDING)
  // Public share-link capability token (Unit 38): null = not shared.
  shareToken  String?      @unique

  overallScore Int?
  verdict      ReportVerdict?
  scores       Json?

  report          Json?
  audienceSummary Json?
  confidence      Json?
  sampleSize      Json?

  reportSchemaVersion Int?
  // Scoring ALGORITHM version (@kol-fit/shared SCORING_VERSION), distinct from
  // reportSchemaVersion above. Instant reuse only matches the current value, so
  // a scoring change cannot serve a previous algorithm's report. Null = written
  // before the column existed (pre-2026-07-20) and therefore never reusable.
  scoringVersion      Int?
  llmModel            String?
  promptVersion       String?

  errorCode    String?
  errorMessage String?

  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  generatedAt DateTime? @db.Timestamptz

  request        AnalysisRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  workspace      Workspace?             @relation(fields: [workspaceId], references: [id])
  evidence       ReportEvidence?
  engagedSamples EngagedAccountSample[]
  usageLogs      ProviderUsageLog[]

  @@index([workspaceId, createdAt])
  @@index([status])
  @@index([verdict])
  @@index([createdAt])
}

model ReportEvidence {
  id       String @id @default(cuid())
  reportId String @unique

  evidence    Json
  sampleSizes Json?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model EngagedAccountSample {
  id        String           @id @default(cuid())
  reportId  String
  handle    String?
  accountId String?
  source    EngagementSource
  bucket    String?
  signals   Json?

  createdAt DateTime @default(now()) @db.Timestamptz

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([bucket])
}

model ProviderUsageLog {
  id          String  @id @default(cuid())
  requestId   String?
  reportId    String?
  workspaceId String?

  provider  String
  operation String
  requests  Int?
  tokensIn  Int?
  tokensOut Int?
  costUsd   Decimal? @db.Decimal(12, 6)
  meta      Json?

  createdAt DateTime @default(now()) @db.Timestamptz

  request AnalysisRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  report  Report?          @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([requestId])
  @@index([reportId])
}

// Generic key-value cache for provider data (profiles/tweets/engagement),
// reused across requests. Added in Unit 19. Keys are versioned + normalized
// (e.g. "tw:v1:profile:uniswap"); payload holds a normalized shared-type value.
model ProviderCache {
  key       String   @id
  provider  String
  payload   Json
  fetchedAt DateTime @default(now()) @db.Timestamptz
  expiresAt DateTime @db.Timestamptz

  @@index([expiresAt])
}

// Detailed-report concierge requests (Unit 35): a user asks for a manually
// curated analysis, delivered to their Telegram by the operator. Available at
// any time (not only past the Unit 34 tier walls). Fulfillment is manual —
// status is flipped from the admin panel.
enum DetailedRequestStatus {
  NEW
  SENT
  DISMISSED
}

model DetailedReportRequest {
  id      String  @id @default(cuid())
  // Owner cookie or user id (mirrors AnalysisRequest.ownerId semantics).
  ownerId String
  userId  String?

  // Optional link to the self-serve analysis this request is about.
  analysisRequestId String?
  orgHandle         String?
  kolHandle         String?

  telegram String
  xHandle  String
  // Email for follow-up when the requester isn't signed in; for signed-in
  // users the account email is copied here at create time (Unit 36.1).
  email    String?
  note     String?

  status      DetailedRequestStatus @default(NEW)
  createdAt   DateTime              @default(now()) @db.Timestamptz
  fulfilledAt DateTime?             @db.Timestamptz
  // Chat-style unread marker (Unit 40.1): set when the operator first views
  // the leads queue; the nav badge counts unseen, independent of workflow status.
  seenAt      DateTime?             @db.Timestamptz

  @@index([status, createdAt])
  @@index([ownerId, createdAt])
}
